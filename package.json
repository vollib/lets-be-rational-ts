{
  "name": "lets-be-rational",
  "version": "0.1.0",
  "description": "TypeScript port of Peter Jaeckel's LetsBeRational normalized Black and implied volatility routines.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/vollib/lets-be-rational-ts.git"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/test/*.test.js"
  },
  "dependencies": {
    "cody-special": "^0.1.0",
    "piecewise-rational": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "typescript": "^5.4.5",
    "vollib-test-vectors": "git+ssh://git@github.com/vollib/vollib-test-vectors.git#c5fb306508779646bf70edb57f26ccf4fbaa540f"
  },
